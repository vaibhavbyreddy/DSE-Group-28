@techReport{Castro2026,
   abstract = {Objective: Design an unmanned modular test bed for a wide range of experimental aerospace components in flight conditions. The UAV is powered by a micro turbine running on SAF for a minimum payload of 5 kilograms and a minimum volume of 5 litres, also with a minimum endurance of 30 minutes. The wing, tail and payload bay shall be modular to enable multiple configurations. The weight of any structure being tested is discounted from the payload. The payload also covers dedicated avionics, actuators and sensors used for the flight tests We are racing toward a net-zero future by 2050, driving a fundamental shift in aircraft configuration. To achieve unprecedented fuel efficiency, future airliners will utilise ultra-lightweight, High-Aspect-Ratio (HAR) wings. While aerodynamically superior, these slender structures introduce a new frontier of engineering challenges: they are highly flexible and susceptible to complex aeroelastic phenomena, including gust loads and control reversal. The solution lies in adopting an active aeroelastic wing to enable high flexibility while controlling these complex phenomena. In this new paradigm, structural stiffness is replaced by smart, active control systems like Active Flutter Suppression (AFS) and Gust Load Alleviation (GLA). However, validating these high-risk technologies on manned aircraft is dangerous, and wind tunnels cannot accurately replicate the complex coupling between flight mechanics and structural dynamics. In this Design Synthesis Exercise, your team will design the critical tool needed to bridge this gap: a Micro-turbine powered unmanned flying laboratory. This is not a standard drone design project. You will develop a high-performance, 50kg demonstrator capable of reaching transonic speeds (Mach 0.75) using Sustainable Aviation Fuel (SAF). The aircraft must feature a modular architecture, allowing for interchangeable wings and tails to physically simulate stable, neutral, and unstable flight configurations. Your design will serve as a real-world testbed to validate next-generation actuation systems and flight control laws, enabling researchers to safely push the boundaries of aeroelasticity.},
   author = {Saullo G P Castro},
   title = {Project Guide Design Synthesis Exercise 2025-2026 Q4 Micro turbine-powered unmanned flying laboratory design for testing highly flexible aircraft},
   year = {2026}
}

